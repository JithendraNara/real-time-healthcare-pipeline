{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Jithendranara/real-time-healthcare-pipeline/schemas/lab_result.json",
  "title": "LabResultEvent",
  "description": "Discrete lab result (component-level)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id", "event_time", "ingestion_time", "source", "schema_version",
    "patient_id", "order_id", "test_code", "test_name", "collected_at", "resulted_at"
  ],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_time": { "type": "string", "format": "date-time" },
    "ingestion_time": { "type": "string", "format": "date-time" },
    "source": { "type": "string", "enum": ["ehr", "iot", "lab_device", "wearable", "monitor", "synthea", "edge_gateway"] },
    "schema_version": { "type": "integer", "default": 1 },
    "patient_id": { "type": "string" },
    "encounter_id": { "type": ["string", "null"] },
    "order_id": { "type": "string" },
    "test_code": { "type": "string", "description": "LOINC code" },
    "test_name": { "type": "string" },
    "value_numeric": { "type": ["number", "null"] },
    "value_text": { "type": ["string", "null"] },
    "unit": { "type": ["string", "null"] },
    "reference_low": { "type": ["number", "null"] },
    "reference_high": { "type": ["number", "null"] },
    "abnormal_flag": { "type": ["string", "null"], "enum": ["L", "H", "LL", "HH", "A", "AA", "N", null] },
    "collected_at": { "type": "string", "format": "date-time" },
    "resulted_at": { "type": "string", "format": "date-time" }
  }
}
